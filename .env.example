# Backend

# A random secret key for JWT signing/authentication
SECRET_KEY=your_secret_key_here

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Public URL of the backend API
BASE_URL=http://localhost:8000

# PostgreSQL Configuration
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# DB Host
# Docker Compose: db
# Local PostgreSQL: localhost
DB_HOST=db

DB_PORT=5432

# Use "pclocal" when running Pinecone Local
PINECONE_API_KEY=pclocal

# Pinecone index name
PINECONE_INDEX_NAME=your_index_name

# Pinecone index host
# Docker Compose: http://host.docker.internal:5081
# Local development: http://localhost:5081
PINECONE_INDEX_HOST=http://host.docker.internal:5081

# Pinecone API host
# Docker Compose: http://pinecone:8000
# Local development: http://localhost:8000
PINECONE_HOST=http://pinecone:8000


# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000